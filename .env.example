# 环境配置示例

# 复制此文件为 .env.local 并填入实际值

# 网站基本信息
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=沐Studio音乐

# 联系信息
NEXT_PUBLIC_CONTACT_EMAIL=info@mustudio.com
NEXT_PUBLIC_CONTACT_PHONE=+86 138 0000 0000
NEXT_PUBLIC_CONTACT_ADDRESS=北京市朝阳区

# 表单提交 (选择一种方案)

# 方案 1: Formspree
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# 方案 2: EmailJS
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# 分析统计
NEXT_PUBLIC_GA_ID=your_google_analytics_id

# 社交媒体
NEXT_PUBLIC_WECHAT=your_wechat_id
NEXT_PUBLIC_WEIBO=your_weibo_url
NEXT_PUBLIC_DOUYIN=your_douyin_url

# API 端点 (如果使用自建后端)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
